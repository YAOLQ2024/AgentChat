# Docker Compose 项目名称
COMPOSE_PROJECT_NAME=agentchat

# 可选的构建/运行时代理设置
# 如果本地 HTTP/Mixed 代理端口不是 7897，请修改对应端口
HTTP_PROXY=http://host.docker.internal:7897
HTTPS_PROXY=http://host.docker.internal:7897

# Docker 内部不需要走代理的服务名称
NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal,mysql,redis,minio,backend,frontend

# 数据库凭据，供 docker-compose.yml 和 docker_config.yaml 使用
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_PASSWORD=your_mysql_password

# MinIO 根凭据，供 MinIO 容器和后端存储配置使用
MINIO_ROOT_USER=your_minio_root_user
MINIO_ROOT_PASSWORD=your_minio_root_password

# 模型服务商 API 密钥
MIMO_API_KEY=your_mimo_api_key
SILICONFLOW_API_KEY=your_siliconflow_api_key

# 外部工具 API 密钥
WEATHER_API_KEY=your_weather_api_key
TAVILY_API_KEY=your_tavily_api_key
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
DELIVERY_API_KEY=your_delivery_api_key
BOCHA_API_KEY=your_bocha_api_key

# 对象存储（OSS 模式）凭据
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# 微信集成凭据
WECHAT_TOKEN=your_wechat_token
WECHAT_APP_ID=your_wechat_app_id
WECHAT_SECRET=your_wechat_secret

# Langfuse 链路追踪凭据
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_USER_ID=your_langfuse_user_id
